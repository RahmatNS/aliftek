<Files ".env">
    Order allow,deny
    Deny from all
</Files>

# Ensure DirectoryIndex is set for trailing slashes
DirectoryIndex index.html

RewriteEngine On

# If the request is for a directory without a trailing slash, redirect to add it
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*[^/])$ /$1/ [L,R=301]

# Handle 404s by showing the custom 404 page
ErrorDocument 404 /404.html
